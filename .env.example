PORT=3000
API_BASE_URL="http://127.0.0.1:8000"
APP_URL="http://localhost:3000"
VITE_ENABLE_LIVE_BINANCE=false

# Shared secret for Node → FastAPI internal calls.
# Leave empty in development (auth is disabled when unset).
# In production, set to a random 32+ char string and pass to both services.
INTERNAL_API_KEY=""

# Max analysis requests per minute per IP (default: 20)
ANALYSIS_RATE_LIMIT=20

# Path to the DGWM quant project root (only needed for DGWM runtime diagnostic).
# Leave empty in Cloud Run — the adapter will report exists=false gracefully.
DGWM_ROOT=""
