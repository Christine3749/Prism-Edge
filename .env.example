PORT=3000
API_BASE_URL="http://127.0.0.1:8000"
APP_URL="http://localhost:3000"
VITE_ENABLE_LIVE_BINANCE=false

# Shared secret for Node → FastAPI internal calls.
# Leave empty in development (auth is disabled when unset).
# In production, set to a random 32+ char string and pass to both services.
INTERNAL_API_KEY=""

# Max analysis requests per minute per IP (default: 20)
ANALYSIS_RATE_LIMIT=20

# Path to the DGWM quant project root (only needed for DGWM runtime diagnostic).
# Leave empty in Cloud Run — the adapter will report exists=false gracefully.
DGWM_ROOT=""
# HalfSphere / HS membership binding for Prism Edge.
# Frontend sends Authorization: Bearer <HS Supabase access_token> to Node APIs.
HS_SUPABASE_URL="https://hrtynofmjcumuanjvpxz.supabase.co"
HS_SUPABASE_ANON_KEY=""
# Server-only fallback for precise membership reads. Never expose this to the browser.
HS_SUPABASE_SERVICE_ROLE_KEY=""
HS_PRODUCT_CODE="msir_prism"
# off = local/dev compatible, warn = allow with headers, enforce = block unauthorized access. Production should use enforce.
HS_MEMBERSHIP_ENFORCEMENT="off"
